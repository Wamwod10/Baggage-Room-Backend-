generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
}

enum LockerSize {
  S
  M
  L
  XL
}

enum LockerStatus {
  EMPTY
  BUSY
  DELAYED
  SERVICE
}

enum OrderStatus {
  ACTIVE
  PICKED_UP
  CANCELLED
  DELAYED
}

enum Currency {
  UZS
  USD
  RUB
  EUR
}

enum PaymentType {
  CASH
  CARD
  TRANSFER
  DEBT
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  ORDER_PAYMENT
  DEBT_CLOSE
  EXPENSE
  INKASSA
  MANUAL_CORRECTION
}

enum CashDirection {
  IN
  OUT
}

enum DebtStatus {
  OPEN
  CLOSED
}

enum NotificationType {
  INFO
  WARNING
  DANGER
  SUCCESS
}

model Branch {
  id               String            @id @default(cuid())
  name             String            @unique
  code             String            @unique
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  lockers          Locker[]
  tariffs          Tariff[]
  orders           Order[]
  shifts           Shift[]
  expenses         Expense[]
  inkassa          Inkassa[]
  cashMovements    CashMovement[]
  debts            Debt[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  telegramSetting  TelegramSetting?
}

model User {
  id                    String          @id @default(cuid())
  login                 String          @unique
  name                  String
  passwordHash          String
  role                  Role
  branchId              String?
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  branch                Branch?         @relation(fields: [branchId], references: [id])
  createdOrders         Order[]         @relation("OrderCreatedBy")
  pickedUpOrders        Order[]         @relation("OrderPickedUpBy")
  cancelledOrders       Order[]         @relation("OrderCancelledBy")
  openedShifts          Shift[]         @relation("ShiftOpenedBy")
  closedShifts          Shift[]         @relation("ShiftClosedBy")
  expenses              Expense[]
  inkassa               Inkassa[]
  cashMovements         CashMovement[]
  closedDebts           Debt[]          @relation("DebtClosedBy")
  auditLogs             AuditLog[]

  @@index([branchId])
}

model Locker {
  id              String        @id @default(cuid())
  branchId        String
  number          Int
  size            LockerSize
  status          LockerStatus  @default(EMPTY)
  currentOrderId  String?
  serviceReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  branch          Branch        @relation(fields: [branchId], references: [id])
  currentOrder    Order?        @relation("LockerCurrentOrder", fields: [currentOrderId], references: [id])
  orderItems      OrderItem[]

  @@unique([branchId, number])
  @@index([branchId])
  @@index([status])
}

model Tariff {
  id             String      @id @default(cuid())
  branchId       String
  size           LockerSize
  price1h        Int
  price12h       Int
  price24h       Int
  price48h       Int
  price72h       Int
  after72hPrice  Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  branch         Branch      @relation(fields: [branchId], references: [id])

  @@unique([branchId, size])
  @@index([branchId])
}

model Order {
  id                 String        @id @default(cuid())
  orderNumber        String        @unique
  branchId           String
  clientName         String
  phone              String
  passport           String?
  status             OrderStatus   @default(ACTIVE)
  tariffHours        Int
  customHours        Int?
  currency           Currency      @default(UZS)
  paymentType        PaymentType
  calculatedAmount   Int           @default(0)
  discountAmount     Int           @default(0)
  discountReason     String?
  finalAmount        Int           @default(0)
  realPaidAmount     Int           @default(0)
  paymentDifference  Int           @default(0)
  realPaidReason     String?
  overtimeHours      Int           @default(0)
  overtimeAmount     Int           @default(0)
  checkIn            DateTime
  plannedCheckOut    DateTime
  realPickupTime     DateTime?
  note               String?
  createdById        String
  pickedUpById       String?
  cancelledById      String?
  cancelReason       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  branch             Branch        @relation(fields: [branchId], references: [id])
  createdBy          User          @relation("OrderCreatedBy", fields: [createdById], references: [id])
  pickedUpBy         User?         @relation("OrderPickedUpBy", fields: [pickedUpById], references: [id])
  cancelledBy        User?         @relation("OrderCancelledBy", fields: [cancelledById], references: [id])
  items              OrderItem[]
  currentLockers     Locker[]      @relation("LockerCurrentOrder")
  cashMovements      CashMovement[]
  debt               Debt?
  notifications      Notification[]

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@index([phone])
}

model OrderItem {
  id              String      @id @default(cuid())
  orderId         String
  lockerId        String
  lockerNumber    Int
  size            LockerSize
  count           Int         @default(1)
  tariffHours     Int
  unitPrice       Int         @default(0)
  originalPrice   Int
  discountAmount  Int         @default(0)
  finalPrice      Int
  currency        Currency
  createdAt       DateTime    @default(now())
  order           Order       @relation(fields: [orderId], references: [id])
  locker          Locker      @relation(fields: [lockerId], references: [id])

  @@index([orderId])
  @@index([lockerId])
}

model Shift {
  id                  String        @id @default(cuid())
  branchId            String
  openedById          String
  closedById          String?
  handoverToName      String?
  acceptedFromName    String?
  openingCash         Int           @default(0)
  acceptedCash        Int           @default(0)
  closingCash         Int?
  totalRevenue        Int           @default(0)
  cashRevenue         Int           @default(0)
  cardRevenue         Int           @default(0)
  transferRevenue     Int           @default(0)
  debtAmount          Int           @default(0)
  expenseAmount       Int           @default(0)
  inkassaAmount       Int           @default(0)
  systemExpectedCash  Int           @default(0)
  difference          Int           @default(0)
  openedAt            DateTime      @default(now())
  closedAt            DateTime?
  status              ShiftStatus   @default(OPEN)
  branch              Branch        @relation(fields: [branchId], references: [id])
  openedBy            User          @relation("ShiftOpenedBy", fields: [openedById], references: [id])
  closedBy            User?         @relation("ShiftClosedBy", fields: [closedById], references: [id])
  expenses            Expense[]
  inkassa             Inkassa[]
  cashMovements       CashMovement[]

  @@index([branchId])
  @@index([status])
  @@index([openedAt])
}

model Expense {
  id           String      @id @default(cuid())
  branchId     String
  shiftId      String?
  category     String
  reason       String
  amount       Int
  currency     Currency    @default(UZS)
  createdById  String
  createdAt    DateTime    @default(now())
  branch       Branch      @relation(fields: [branchId], references: [id])
  shift        Shift?      @relation(fields: [shiftId], references: [id])
  createdBy    User        @relation(fields: [createdById], references: [id])

  @@index([branchId])
  @@index([createdAt])
}

model Inkassa {
  id            String      @id @default(cuid())
  branchId      String
  shiftId       String?
  receiverName  String
  amount        Int
  currency      Currency    @default(UZS)
  note          String?
  createdById   String
  createdAt     DateTime    @default(now())
  branch        Branch      @relation(fields: [branchId], references: [id])
  shift         Shift?      @relation(fields: [shiftId], references: [id])
  createdBy     User        @relation(fields: [createdById], references: [id])

  @@index([branchId])
  @@index([createdAt])
}

model CashMovement {
  id           String            @id @default(cuid())
  branchId     String
  shiftId      String?
  orderId      String?
  type         CashMovementType
  direction    CashDirection
  amount       Int
  currency     Currency          @default(UZS)
  paymentType  PaymentType?
  note         String?
  createdById  String
  createdAt    DateTime          @default(now())
  branch       Branch            @relation(fields: [branchId], references: [id])
  shift        Shift?            @relation(fields: [shiftId], references: [id])
  order        Order?            @relation(fields: [orderId], references: [id])
  createdBy    User              @relation(fields: [createdById], references: [id])

  @@index([branchId])
  @@index([shiftId])
  @@index([createdAt])
}

model Debt {
  id          String      @id @default(cuid())
  orderId     String      @unique
  branchId    String
  clientName  String
  phone       String
  amount      Int
  currency    Currency    @default(UZS)
  status      DebtStatus   @default(OPEN)
  closedAt    DateTime?
  closedById  String?
  createdAt   DateTime    @default(now())
  order       Order       @relation(fields: [orderId], references: [id])
  branch      Branch      @relation(fields: [branchId], references: [id])
  closedBy    User?       @relation("DebtClosedBy", fields: [closedById], references: [id])

  @@index([branchId])
  @@index([phone])
  @@index([status])
}

model AuditLog {
  id           String    @id @default(cuid())
  branchId     String?
  userId       String?
  entityType   String
  entityId     String
  action       String
  oldValue     Json?
  newValue     Json?
  description  String?
  createdAt    DateTime  @default(now())
  branch       Branch?   @relation(fields: [branchId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])

  @@index([branchId])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id              String            @id @default(cuid())
  branchId        String
  type            NotificationType
  title           String
  message         String
  isRead          Boolean           @default(false)
  priority        Int               @default(1)
  relatedOrderId  String?
  createdAt       DateTime          @default(now())
  branch          Branch            @relation(fields: [branchId], references: [id])
  relatedOrder    Order?            @relation(fields: [relatedOrderId], references: [id])

  @@index([branchId])
  @@index([isRead])
  @@index([createdAt])
}

model TelegramSetting {
  id                       String    @id @default(cuid())
  branchId                 String    @unique
  botToken                 String?
  groupId                  String?
  enabled                  Boolean   @default(false)
  newOrderEnabled          Boolean   @default(true)
  shiftOpenEnabled         Boolean   @default(true)
  shiftCloseEnabled        Boolean   @default(true)
  orderCancelEnabled       Boolean   @default(true)
  delayedBaggageEnabled    Boolean   @default(true)
  overtimePaymentEnabled   Boolean   @default(true)
  debtClosedEnabled        Boolean   @default(true)
  inkassaEnabled           Boolean   @default(true)
  expenseEnabled           Boolean   @default(true)
  orderEditEnabled         Boolean   @default(true)
  lockerTransferEnabled    Boolean   @default(true)
  lockerServiceEnabled     Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  branch                   Branch    @relation(fields: [branchId], references: [id])
}
