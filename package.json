{
  "name": "baggage-room-management-backend",
  "version": "1.0.0",
  "description": "Production backend for Baggage Room Management System",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "prisma generate",
    "test": "node --require dotenv/config test/run.js",
    "test:sheets:real": "node scripts/googleSheetsRealMappingTest.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "prisma:seed": "node prisma/seed.js",
    "reset:data": "node scripts/resetProductionData.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.21.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.9.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
